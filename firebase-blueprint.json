{
  "entities": {
    "citizen": {
      "title": "Citizen",
      "description": "Resident or Citizen details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "block": { "type": "string" },
        "houseNumber": { "type": "string" },
        "rtNumber": { "type": "string" },
        "gender": { "type": "string" },
        "relationship": { "type": "string" },
        "occupation": { "type": "string" },
        "phone": { "type": "string" },
        "isResident": { "type": "boolean" }
      }
    },
    "user": {
      "title": "User",
      "description": "User login account",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "isActive": { "type": "boolean" },
        "lastLogin": { "type": "string" }
      }
    },
    "borrow": {
